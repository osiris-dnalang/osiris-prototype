#!/usr/bin/env python3
"""
OSIRIS demo stub - deterministic, offline.
Shows a simple 3-agent orchestration trace for presentation/demo purposes.
"""
import time
import json


def agent(name, input_data):
    print(f"[{name}] received: {input_data}")
    time.sleep(0.25)
    output = f"{name}-result-{len(str(input_data))}"
    print(f"[{name}] produced: {output}")
    return output


def main():
    print("OSIRIS Demo (offline, deterministic)\n")
    trace = []
    data = "initial-seed"
    a1 = agent("Perceptor", data); trace.append(a1)
    a2 = agent("Reasoner", a1); trace.append(a2)
    a3 = agent("Executor", a2); trace.append(a3)
    print("\nDemo complete. Trace:")
    for i, t in enumerate(trace, 1):
        print(f"  {i}. {t}")
    print("\nResult JSON:")
    print(json.dumps({"trace": trace, "final": trace[-1]}, indent=2))


if __name__ == "__main__":
    main()
